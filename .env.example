# ---------------------------------------------------------------------------
# Rollun site — environment variables (UPPER_SNAKE, never hardcoded in source).
# Copy to `.env` and fill in real local values. `.env` is gitignored.
# ---------------------------------------------------------------------------

# Postgres connection string used by the Payload Postgres adapter.
# Local (host):  postgres://postgres:postgres@localhost:5432/rollun
# Docker compose: postgres://postgres:postgres@postgres:5432/rollun
DATABASE_URI=postgres://postgres:postgres@localhost:5432/rollun

# Secret used by Payload to sign/encrypt tokens. Use a long random string.
# Generate e.g.: openssl rand -hex 32
PAYLOAD_SECRET=change-me-to-a-long-random-secret

# Base URL of the Rollun CRM API (contact form / offers integration).
CRM_API_URL=https://crm.example.com/api

# Shared secret guarding the on-demand revalidation endpoint.
REVALIDATION_SECRET=change-me-revalidation-secret
